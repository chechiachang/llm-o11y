{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "bifrost": {
      "npm": "@ai-sdk/openai",
      "name": "Bifrost",
      "options": {
        "baseURL": "http://localhost:8080/v1",
        "apiKey": "dummy"
      },
      "models": {
        "azure/gpt-5.3-codex": {},
        "azure/gpt-5.1-codex-mini": {},
        "azure/gpt-5.4": {},
        "azure/gpt-5.4-mini": {},
        "azure/gpt-5.4-nano": {}
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CTX7_API_KEY}"
      },
      "enabled": false
    }
  },
  "permission": {
    "read": {
      "./**": "allow"
    },
    "edit": {
      "./**": "allow"
    },
    "bash": {
      "./**": "allow",
      "git *": "allow",
      "npm *": "allow",
      "rm *": "deny",
      "grep *": "allow"
    }
  }
}
